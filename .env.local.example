# asg100 安全隐患域会员中心 —— env 模板。复制成 .env.local 填真值（.env.local 不进 git）。
# session 密钥生成：node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"

# ── 共享会员 cookie 密钥（A600/Z200 必须填同一个值，否则跨产品登录态解不开）──
ASG_MEMBER_SESSION_PASSWORD=<generate-with-the-command-above>
ASG_COOKIE_SECURE=false
ASG100_API_PORT=4002

# 本地短信旁路（上线必须删）：用此码可绕过真实验证码登录
MASTER_OTP_CODE=888888

# 个人历史聚合：各业务积木库路径（只读挂载）
ASG_HAZARD_DB_PATH=../A600-隐患识别-hazard-detect/data/hazard-detect.db
ASG_DOC_DB_PATH=../Z200-安防文档库-doc-library/data/doc-library.db

# ── Phase 5-6 真短信/真支付凭证（留空自动走 fake/DEV 模式）──
# SMSBAO_USER=
# SMSBAO_PASS=
# SMSBAO_SIGN=【谨世智能】   # 与 A200 同值；值必须自带【】方括号，留空则用代码内默认「【谨世智能】」
# WECHAT_OFFICIAL_ACCOUNT_APPID=
# WECHAT_OFFICIAL_ACCOUNT_SECRET=
# WECHAT_PAY_MCH_ID=1683774591
# WECHAT_PAY_SERIAL_NO=
# WECHAT_PAY_PRIVATE_KEY_B64=
# WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_PUBLIC_KEY_B64=
# WECHAT_PAY_PUBLIC_KEY_ID=
# ASG_WECHAT_NOTIFY_URL=
# ASG_OAUTH_REDIRECT_URI=

# ── 部署到子路径时打开（cookie path 收敛到域前缀，避免全站广播）──
# VITE_BASE_PATH=/asg100/
# ASG_COOKIE_PATH=/asg100
