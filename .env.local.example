# ── 后端讯飞 API（server.js 用，server 进程持 key，浏览器 bundle 不再包含）──
IFLYTEK_API_KEY=<api-key>:<api-secret>
IFLYTEK_MODEL=astron-code-latest

# ── iron-session 密钥 ──
# 必须 ≥32 字符。建议命令生成：
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
ASG100_SESSION_PASSWORD=<generate-with-the-command-above>
# 本地 dev 留 false；HTTPS 部署改 true 或删掉这行
ASG100_COOKIE_SECURE=false

# ── API 服务端口（与 vite.config.js 的 proxy target 对应）──
# vite dev 跑 :3000，server.js 跑 :4002，vite 把 /api/* 转发到 server.js
ASG100_API_PORT=4002

# ── 短信宝（Phase 1，本地调试可留空，用 MASTER_OTP_CODE 代替）──
# SMSBAO_USER=<手机号>
# SMSBAO_PASSWORD=<md5(密码)>
# MASTER_OTP_CODE=888888

# ── 微信支付（Phase 2）──
# ASG100_WX_APPID=<服务号 AppID>
# ASG100_WX_MCH_ID=1683774591
# ASG100_WX_API_V3_KEY=<APIv3密钥>
# ASG100_WX_PRIVATE_KEY_PATH=<私钥文件路径>
# ASG100_WX_SERIAL_NO=<证书序列号>
# ASG100_WX_NOTIFY_URL=https://<域名>/asg100/api/pay/notify
# ASG100_WX_FAKE_PAY=true

# ── 部署到 /asg100/ 子路径时打开 ──
# VITE_BASE_PATH=/asg100/
# ASG100_COOKIE_PATH=/asg100
